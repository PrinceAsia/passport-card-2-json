# --- App ---
APP_NAME=document-ocr-api
APP_ENV=development
LOG_LEVEL=INFO
LOG_PII=false

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=2

# --- Upload limits ---
MAX_FILE_SIZE_MB=10

# --- OCR ---
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANGS=uzb+uzb_cyrl+rus+eng
TESSERACT_PSM=6
OCR_MIN_CONFIDENCE=60
OCR_FALLBACK_ENABLED=false

# --- PDF ---
PDF_DPI=300
PDF_MAX_PAGES=10

# --- Preprocessing toggles ---
# Threshold + denoise default OFF: helps low-contrast scans, hurts clean photos.
PREPROCESS_AUTO_ORIENT=true
PREPROCESS_DESKEW=true
PREPROCESS_GRAYSCALE=true
PREPROCESS_THRESHOLD=false
PREPROCESS_DENOISE=false
PREPROCESS_PERSPECTIVE_WARP=true

# --- Security ---
# Comma-separated list of allowed API keys. Leave empty to disable auth.
API_KEYS=
# Comma-separated list of allowed CORS origins. * allowed.
CORS_ORIGINS=*
RATE_LIMIT=30/minute

# --- Observability ---
ENABLE_METRICS=true
